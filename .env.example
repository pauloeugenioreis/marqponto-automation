# Nome do sistema (prefixo nas mensagens do Telegram, ex: "Irede - Ponto registrado!")
SISTEMA_PONTO=Irede

# Credenciais MarqPonto
MARQPONTO_USER=seu.email@empresa.com.br
MARQPONTO_PASS=sua_senha_aqui

# URLs do MarqPonto
LOGIN_URL=https://web.marqponto.com.br/
PONTO_URL=https://web.marqponto.com.br/clock-ins

# Telegram (notificações e comandos)
# 1. Fale com @BotFather no Telegram → /newbot → copie o token
# 2. Fale com @userinfobot → copie seu Chat ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# GitHub Gist (persistência de datas desativadas)
# 1. Crie um token em github.com/settings/tokens/new (scope: gist)
# 2. Crie um Gist secreto em gist.github.com com arquivo app-marqponto-disabled-dates.json contendo []
GH_GIST_TOKEN=
GIST_ID=

# Configuração do Puppeteer
# HEADLESS=false   # descomente para ver o browser
# DEBUG=true       # descomente para screenshots + browser aberto
# DRY_RUN=false    # descomente para simular ações sem clicar

# Chrome/Chromium para o Puppeteer:
# 1) Instalar Chrome via Puppeteer (recomendado): npx puppeteer browsers install chrome
# 2) Ou usar Chrome do sistema — descomente e ajuste o caminho:
# Windows (Chrome instalado): PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
# Linux/VPS: PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
# PUPPETEER_EXECUTABLE_PATH=

# Geolocalização (coordenadas do escritório para o MarqPonto aceitar o ponto)
# A geolocalização varia por dia da semana:
# Segunda/Terça/Quarta
GEO_LAT_SEG_TER_QUA=-3.0920902438448383
GEO_LNG_SEG_TER_QUA=-60.00604977562166
# Quinta/Sexta
GEO_LAT_QUI_SEX=-3.054679
GEO_LNG_QUI_SEX=-60.032772
